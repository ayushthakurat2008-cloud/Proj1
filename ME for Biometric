import java.util.*;

/*
 Project Title:
 Smart Biometric Medical Equipment for Employee Onboarding – MedLife

 Description:
 Software-based simulation of a medical biometric system
 for onboarding newly hired employees.
*/

// ======================= Employee Class =======================
class Employee {
    private int empId;
    private String name;
    private String department;
    private String biometricHash;

    public Employee(int empId, String name, String department, String biometricHash) {
        this.empId = empId;
        this.name = name;
        this.department = department;
        this.biometricHash = biometricHash;
    }

    public int getEmpId() {
        return empId;
    }

    public String getName() {
        return name;
    }

    public String getDepartment() {
        return department;
    }

    public String getBiometricHash() {
        return biometricHash;
    }
}

// ======================= Biometric System Class =======================
class BiometricSystem {

    // Simulated biometric capture
    public String captureBiometric(String biometricInput) {
        return encryptBiometric(biometricInput);
    }

    // Encrypt biometric using hashCode (simulation)
    private String encryptBiometric(String input) {
        return Integer.toString(input.hashCode());
    }

    // Verification
    public boolean verifyBiometric(String input, String storedHash) {
        String inputHash = encryptBiometric(input);
        return inputHash.equals(storedHash);
    }
}

// ======================= HR Admin Class =======================
class HRAdmin {
    private Map<Integer, Employee> employeeDatabase = new HashMap<>();
    private BiometricSystem biometricSystem = new BiometricSystem();
    private int empCounter = 1000;

    // Register new employee
    public Employee registerEmployee(String name, String department, String biometricData) {
        empCounter++;
        String biometricHash = biometricSystem.captureBiometric(biometricData);
        Employee employee = new Employee(empCounter, name, department, biometricHash);
        employeeDatabase.put(empCounter, employee);

        System.out.println("✅ Employee Registered Successfully");
        System.out.println("Generated Employee ID: " + empCounter);
        return employee;
    }

    // Verify employee biometric
    public boolean approveEmployee(int empId, String biometricInput) {
        Employee emp = employeeDatabase.get(empId);

        if (emp == null) {
            System.out.println("❌ Employee not found");
            return false;
        }

        boolean status = biometricSystem.verifyBiometric(
                biometricInput,
                emp.getBiometricHash()
        );

        if (status) {
            System.out.println("✅ Biometric Verified. Employee Approved.");
            return true;
        } else {
            System.out.println("❌ Biometric Verification Failed.");
            return false;
        }
    }

    // Display all employees
    public void displayEmployees() {
        System.out.println("\n---- Employee Database ----");
        for (Employee e : employeeDatabase.values()) {
            System.out.println(
                "ID: " + e.getEmpId() +
                " | Name: " + e.getName() +
                " | Dept: " + e.getDepartment()
            );
        }
    }
}

// ======================= Testing + Implementation =======================
public class MedLifeBiometricSystem {

    public static void main(String[] args) {

        System.out.println("=== MedLife Biometric Medical Equipment System ===\n");

        HRAdmin hrAdmin = new HRAdmin();

        // -------- TEST CASE 1: Register Employee --------
        Employee emp1 = hrAdmin.registerEmployee(
                "Ayush Thakur",
                "IT",
                "fingerprint_ayush"
        );

        // -------- TEST CASE 2: Correct Biometric Verification --------
        boolean test1 = hrAdmin.approveEmployee(
                emp1.getEmpId(),
                "fingerprint_ayush"
        );

        // -------- TEST CASE 3: Incorrect Biometric Verification --------
        boolean test2 = hrAdmin.approveEmployee(
                emp1.getEmpId(),
                "wrong_fingerprint"
        );

        // -------- TEST CASE 4: Invalid Employee ID --------
        boolean test3 = hrAdmin.approveEmployee(
                9999,
                "fingerprint"
        );

        // -------- Display Database --------
        hrAdmin.displayEmployees();

        // -------- Final Test Result --------
        System.out.println("\n=== TEST SUMMARY ===");
        System.out.println("Valid Biometric Test: " + (test1 ? "PASSED ✅" : "FAILED ❌"));
        System.out.println("Invalid Biometric Test: " + (!test2 ? "PASSED ✅" : "FAILED ❌"));
        System.out.println("Invalid Employee Test: " + (!test3 ? "PASSED ✅" : "FAILED ❌"));

        System.out.println("\n✅ System Implementation Completed Successfully");
    }
}


